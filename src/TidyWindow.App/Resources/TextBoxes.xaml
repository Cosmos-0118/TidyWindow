<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Palette for custom text field experience -->
        <SolidColorBrush x:Key="TextBox.BackgroundBrush"
                                         Color="#11213A"/>
        <SolidColorBrush x:Key="TextBox.HoverBrush"
                                         Color="#1A3355"/>
        <SolidColorBrush x:Key="TextBox.ActiveBrush"
                                         Color="#1E3A61"/>
        <SolidColorBrush x:Key="TextBox.DisabledBackgroundBrush"
                                         Color="#182335"/>
        <SolidColorBrush x:Key="TextBox.ReadOnlyBackgroundBrush"
                                         Color="#172842"/>

        <SolidColorBrush x:Key="TextBox.BorderBrush"
                                         Color="#2E4463"/>
        <SolidColorBrush x:Key="TextBox.HoverBorderBrush"
                                         Color="#3C5E86"/>
        <SolidColorBrush x:Key="TextBox.ActiveBorderBrush"
                                         Color="#5FD3FF"/>
        <SolidColorBrush x:Key="TextBox.DisabledBorderBrush"
                                         Color="#31435D"/>
        <SolidColorBrush x:Key="TextBox.ReadOnlyBorderBrush"
                                         Color="#446184"/>
        <SolidColorBrush x:Key="TextBox.FocusBrush"
                                         Color="#4BA4FF"/>
    <SolidColorBrush x:Key="TextBox.ErrorBorderBrush"
                     Color="#F87171"/>

    <SolidColorBrush x:Key="TextBox.ForegroundBrush"
                     Color="#F8FAFC"/>
        <SolidColorBrush x:Key="TextBox.PlaceholderBrush"
                                         Color="#8EA7CB"/>
    <SolidColorBrush x:Key="TextBox.DisabledForegroundBrush"
                     Color="#7687A2"/>
    <SolidColorBrush x:Key="TextBox.ReadOnlyForegroundBrush"
                     Color="#C7D2FE"/>

    <SolidColorBrush x:Key="TextBox.SelectionBrush"
                     Color="#3B82F6"/>

    <CubicEase x:Key="TextBoxEase"
               EasingMode="EaseOut"/>

    <Style x:Key="App.TextBoxStyle"
           TargetType="TextBox">
        <Setter Property="Foreground"
                Value="{StaticResource TextBox.ForegroundBrush}"/>
        <Setter Property="Background"
                Value="{StaticResource TextBox.BackgroundBrush}"/>
        <Setter Property="BorderBrush"
                Value="{StaticResource TextBox.BorderBrush}"/>
        <Setter Property="BorderThickness"
                Value="1"/>
        <Setter Property="Padding"
                Value="12,7"/>
        <Setter Property="MinHeight"
                Value="36"/>
        <Setter Property="FontSize"
                Value="13"/>
        <Setter Property="FontFamily"
                Value="Segoe UI"/>
        <Setter Property="VerticalContentAlignment"
                Value="Center"/>
        <Setter Property="CaretBrush"
                Value="#38BDF8"/>
        <Setter Property="SelectionBrush"
                Value="{StaticResource TextBox.SelectionBrush}"/>
        <Setter Property="SelectionOpacity"
                Value="0.45"/>
        <Setter Property="SnapsToDevicePixels"
                Value="True"/>
        <Setter Property="UseLayoutRounding"
                Value="True"/>
        <Setter Property="TextOptions.TextFormattingMode"
                Value="Display"/>
        <Setter Property="TextOptions.TextRenderingMode"
                Value="ClearType"/>
        <Setter Property="TextOptions.TextHintingMode"
                Value="Animated"/>
        <Setter Property="RenderOptions.ClearTypeHint"
                Value="Enabled"/>
        <Setter Property="Stylus.IsPressAndHoldEnabled"
                Value="False"/>
        <Setter Property="Stylus.IsFlicksEnabled"
                Value="False"/>
        <Setter Property="FocusVisualStyle"
                Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid SnapsToDevicePixels="True">
                        <Border x:Name="Surface"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"/>
                        <Border x:Name="InnerStroke"
                                Margin="1"
                                CornerRadius="7"
                                BorderThickness="1"
                                BorderBrush="#22FFFFFF"
                                IsHitTestVisible="False"/>
                        <Border x:Name="HoverOverlay"
                                Background="{StaticResource TextBox.HoverBrush}"
                                BorderBrush="Transparent"
                                CornerRadius="8"
                                Opacity="0"
                                IsHitTestVisible="False"/>
                        <Border x:Name="ActiveOverlay"
                                Background="{StaticResource TextBox.ActiveBrush}"
                                BorderBrush="Transparent"
                                CornerRadius="8"
                                Opacity="0"
                                IsHitTestVisible="False"/>
                        <Border x:Name="FocusBorder"
                                Margin="-1"
                                CornerRadius="9"
                                BorderThickness="1.5"
                                BorderBrush="{StaticResource TextBox.FocusBrush}"
                                Opacity="0"
                                IsHitTestVisible="False">
                            <Border.Effect>
                                                                <DropShadowEffect BlurRadius="8"
                                                                                                  Color="#904BA4FF"
                                                  Direction="270"
                                                                                                  Opacity="0.35"
                                                  ShadowDepth="0"/>
                            </Border.Effect>
                        </Border>
                                                <TextBlock x:Name="Placeholder"
                                                                  Margin="{TemplateBinding Padding}"
                                                                  VerticalAlignment="Center"
                                                                  Text="{TemplateBinding Tag}"
                                                                  Foreground="{StaticResource TextBox.PlaceholderBrush}"
                                                                  Opacity="0"
                                                                  IsHitTestVisible="False"
                                                                  TextTrimming="CharacterEllipsis"/>
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      Focusable="False"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter TargetName="Surface"
                                    Property="BorderBrush"
                                    Value="{StaticResource TextBox.HoverBorderBrush}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="TextBoxHoverFadeIn">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                         Storyboard.TargetProperty="Opacity"
                                                                                                                 To="0.5"
                                                         Duration="0:0:0.12"
                                                         EasingFunction="{StaticResource TextBoxEase}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard x:Name="TextBoxHoverFadeOut">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0"
                                                         Duration="0:0:0.18"
                                                         EasingFunction="{StaticResource TextBoxEase}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused"
                                 Value="True">
                            <Setter TargetName="Surface"
                                    Property="BorderBrush"
                                    Value="{StaticResource TextBox.ActiveBorderBrush}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="TextBoxActiveFadeIn">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ActiveOverlay"
                                                         Storyboard.TargetProperty="Opacity"
                                                                                                                 To="0.58"
                                                         Duration="0:0:0.12"
                                                         EasingFunction="{StaticResource TextBoxEase}"/>
                                        <DoubleAnimation Storyboard.TargetName="FocusBorder"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         Duration="0:0:0.12"
                                                         EasingFunction="{StaticResource TextBoxEase}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard x:Name="TextBoxActiveFadeOut">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ActiveOverlay"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0"
                                                         Duration="0:0:0.18"
                                                         EasingFunction="{StaticResource TextBoxEase}"/>
                                        <DoubleAnimation Storyboard.TargetName="FocusBorder"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0"
                                                         Duration="0:0:0.18"
                                                         EasingFunction="{StaticResource TextBoxEase}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled"
                                 Value="False">
                            <Setter Property="Foreground"
                                    Value="{StaticResource TextBox.DisabledForegroundBrush}"/>
                            <Setter TargetName="Surface"
                                    Property="Background"
                                    Value="{StaticResource TextBox.DisabledBackgroundBrush}"/>
                            <Setter TargetName="InnerStroke"
                                    Property="Opacity"
                                    Value="0.2"/>
                            <Setter TargetName="Surface"
                                    Property="BorderBrush"
                                    Value="{StaticResource TextBox.DisabledBorderBrush}"/>
                            <Setter TargetName="HoverOverlay"
                                    Property="Opacity"
                                    Value="0"/>
                            <Setter TargetName="ActiveOverlay"
                                    Property="Opacity"
                                    Value="0"/>
                            <Setter TargetName="FocusBorder"
                                    Property="Opacity"
                                    Value="0"/>
                        </Trigger>
                        <Trigger Property="IsReadOnly"
                                 Value="True">
                            <Setter Property="Foreground"
                                    Value="{StaticResource TextBox.ReadOnlyForegroundBrush}"/>
                            <Setter TargetName="Surface"
                                    Property="Background"
                                    Value="{StaticResource TextBox.ReadOnlyBackgroundBrush}"/>
                            <Setter TargetName="InnerStroke"
                                    Property="Opacity"
                                    Value="0.3"/>
                            <Setter TargetName="Surface"
                                    Property="BorderBrush"
                                    Value="{StaticResource TextBox.ReadOnlyBorderBrush}"/>
                            <Setter TargetName="HoverOverlay"
                                    Property="Opacity"
                                    Value="0"/>
                            <Setter TargetName="ActiveOverlay"
                                    Property="Opacity"
                                    Value="0"/>
                        </Trigger>
                        <Trigger Property="Validation.HasError"
                                 Value="True">
                            <Setter TargetName="Surface"
                                    Property="BorderBrush"
                                    Value="{StaticResource TextBox.ErrorBorderBrush}"/>
                            <Setter TargetName="FocusBorder"
                                    Property="BorderBrush"
                                    Value="{StaticResource TextBox.ErrorBorderBrush}"/>
                        </Trigger>
                        <Trigger Property="Text"
                                 Value="">
                            <Setter TargetName="Placeholder"
                                    Property="Opacity"
                                    Value="1"/>
                        </Trigger>
                        <Trigger Property="Text"
                                 Value="{x:Null}">
                            <Setter TargetName="Placeholder"
                                    Property="Opacity"
                                    Value="1"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused"
                                 Value="True">
                            <Setter TargetName="Placeholder"
                                    Property="Opacity"
                                    Value="0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TextBox"
           BasedOn="{StaticResource App.TextBoxStyle}"/>
</ResourceDictionary>
